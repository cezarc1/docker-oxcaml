{
  "name": "OxCaml Baseline (source-build)",
  "build": {
    "dockerfile": "../../images/toolchain/Dockerfile",
    "context": "../..",
    "args": {
      "OXCAML_OPAM_REPOSITORY_REF": "main"
    }
  },
  "remoteUser": "vscode",
  "userEnvProbe": "loginInteractiveShell",
  "hostRequirements": {
    "storage": "64gb"
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "ocamllabs.ocaml-platform",
        "ms-vscode.cpptools",
        "eamodio.gitlens"
      ]
    }
  },
  "updateContentCommand": "with-oxcaml dune build ./examples/hello"
}
